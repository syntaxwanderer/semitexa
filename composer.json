{
    "name": "semitexa/ultimate",
    "description": "Project skeleton: full Semitexa stack for a working SSR site (core + frontend + docs)",
    "version": "v2.0.0",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "semitexa/core": "*",
        "semitexa/tenancy": "*",
        "semitexa/auth": "*",
        "semitexa/locale": "*",
        "semitexa/orm": "*",
        "semitexa/ssr": "*",
        "semitexa/acl": "*",
        "semitexa/docs": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\Modules\\": "src/modules/",
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "semitexa/core": true
        }
    }
}
